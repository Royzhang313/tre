# ============================================
# ERP Builder 后端环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# 应用
APP_NAME=ERP Builder
APP_VERSION=0.1.0
DEBUG=true

# 数据库
DATABASE_URL=postgresql+asyncpg://erp:erp@localhost:5432/erp_builder

# 安全
JWT_SECRET_KEY=change-this-to-a-random-secret
JWT_EXPIRE_SECONDS=7200

# 初始管理员（首次启动自动创建）
ERP_ADMIN_USERNAME=admin
ERP_ADMIN_PASSWORD=change-me
ERP_ADMIN_EMAIL=admin@erp.local

# AI / OCR（可选）
DEEPSEEK_API_KEY=

# CORS（前端地址，生产环境改为实际域名）
CORS_ORIGINS=["http://localhost:5173"]
