# ============================================
# ERP Builder 环境变量配置
# 复制此文件为 .env 并填入实际值
# ============================================

# 应用
APP_NAME=ERP Builder
APP_VERSION=0.1.0
DEBUG=true

# 数据库
DATABASE_URL=postgresql+asyncpg://erp:erp@localhost:5432/erp_builder

# CORS（前端地址）
CORS_ORIGINS=["http://localhost:5173"]
